{
    "name": "zwernemann/magento2-minresolver",
    "description": "Fixes intermittent *.min.js 404 errors (e.g. globals.js) caused by stale baseUrl and double-wrapping of the RequireJS min-resolver in Magento 2.",
    "type": "magento2-module",
    "version": "1.0.0",
    "license": "MIT",
    "authors": [
        {
            "name": "Zwernemann",
            "email": "info@zwernemann.de"
        }
    ],
    "require": {
        "php": ">=7.4.0",
        "magento/framework": ">=103.0.0"
    },
    "autoload": {
        "files": [
            "registration.php"
        ],
        "psr-4": {
            "Zwernemann\\MinResolver\\": ""
        }
    }
}
